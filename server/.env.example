MONGO_URI=your_mongodb_connection_string
PORT=5000
JWT_SECRET=replace_with_a_strong_secret
FRONTEND_URL=http://localhost:3000

# Comma-separated list for CORS. Leave empty to allow all origins.
# Example:
# CORS_ORIGIN=http://localhost:3000,https://icon-computers.onrender.com
CORS_ORIGIN=

# OTP Email (Gmail SMTP example)
# Optional: set SMTP_SERVICE=gmail (if set, SMTP_HOST is ignored)
SMTP_SERVICE=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=yourgmail@gmail.com

# Legacy fallback keys (optional, older config compatibility)
# EMAIL_USER=you@example.com
# EMAIL_PASS=app_password

# Cashfree PG credentials from merchant.cashfree.com
CASHFREE_ENV=sandbox
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_API_VERSION=2023-08-01

# Optional but recommended webhook signing secret
CASHFREE_WEBHOOK_SECRET=your_cashfree_webhook_secret

# Frontend return URL after payment
CASHFREE_RETURN_URL=http://localhost:3000/my-orders

# Optional webhook callback URL (must be public in production)
# CASHFREE_NOTIFY_URL=https://your-domain.com/api/products/payment/cashfree/webhook
